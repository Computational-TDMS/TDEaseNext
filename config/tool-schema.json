{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tdease.app/schemas/tool-definition-v1.json",
  "title": "TDEase Tool Definition Schema",
  "description": "Unified tool definition schema for CLI commands, scripts, and Docker containers",
  "type": "object",
  "required": ["id", "name", "version", "executionMode"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique tool identifier (e.g., 'toppic', 'msconvert')"
    },
    "name": {
      "type": "string",
      "description": "Display name for the tool"
    },
    "version": {
      "type": "string",
      "description": "Tool version"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of what the tool does"
    },
    "executionMode": {
      "type": "string",
      "enum": ["native", "script", "docker", "interactive"],
      "description": "How the tool is executed"
    },
    "command": {
      "type": "object",
      "description": "Command execution configuration",
      "properties": {
        "executable": {
          "type": "string",
          "description": "Path to executable or command name (for native mode)"
        },
        "interpreter": {
          "type": "string",
          "enum": ["python", "Rscript", "bash", "sh", null],
          "description": "Interpreter for script mode (e.g., 'python' for .py scripts)"
        },
        "useUv": {
          "type": "boolean",
          "description": "Whether to use 'uv run' for Python scripts",
          "default": false
        },
        "dockerImage": {
          "type": "string",
          "description": "Docker image name (for docker mode)"
        },
        "dockerCommand": {
          "type": "string",
          "description": "Command to run inside Docker container",
          "default": ""
        }
      }
    },
    "ports": {
      "type": "object",
      "description": "Input and output port definitions",
      "required": ["inputs", "outputs"],
      "properties": {
        "inputs": {
          "type": "array",
          "description": "Input port definitions",
          "items": {
            "type": "object",
            "required": ["id", "name", "dataType"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Port identifier (matches parameter key)"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "dataType": {
                "type": "string",
                "description": "Data type (mzml, fasta, msalign, raw, tsv, etc.)"
              },
              "required": {
                "type": "boolean",
                "description": "Whether this input is required",
                "default": false
              },
              "accept": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Accepted data types"
              },
              "positional": {
                "type": "boolean",
                "description": "Whether this is a positional argument",
                "default": false
              },
              "positionalOrder": {
                "type": "integer",
                "description": "Order for positional arguments (0, 1, 2, ...)",
                "minimum": 0
              },
              "pattern": {
                "type": "string",
                "description": "File path pattern (for input files)"
              }
            }
          }
        },
        "outputs": {
          "type": "array",
          "description": "Output port definitions",
          "items": {
            "type": "object",
            "required": ["id", "name", "pattern"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Output handle identifier"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "dataType": {
                "type": "string",
                "description": "Output data type"
              },
              "pattern": {
                "type": "string",
                "description": "Output file pattern with placeholders (e.g., '{sample}_output.tsv')"
              },
              "handle": {
                "type": "string",
                "description": "Handle name for this output"
              },
              "provides": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Data types this output provides"
              }
            }
          }
        }
      }
    },
    "parameters": {
      "type": "object",
      "description": "CLI parameters (flags, options)",
      "additionalProperties": {
        "type": "object",
        "required": ["flag", "type"],
        "properties": {
          "flag": {
            "type": "string",
            "description": "CLI flag (e.g., '-a', '--activation')"
          },
          "type": {
            "type": "string",
            "enum": ["value", "boolean", "choice"],
            "description": "Parameter type"
          },
          "label": {
            "type": "string",
            "description": "Display label for UI"
          },
          "description": {
            "type": "string",
            "description": "Parameter description"
          },
          "default": {
            "description": "Default value"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this parameter is required",
            "default": false
          },
          "choices": {
            "type": "object",
            "description": "Choice options for type='choice'",
            "additionalProperties": {
              "type": "string",
              "description": "Choice value -> CLI flag mapping"
            }
          },
          "group": {
            "type": "string",
            "description": "Parameter group for UI organization",
            "enum": ["basic", "advanced", "output", "input"]
          },
          "advanced": {
            "type": "boolean",
            "description": "Whether to show in advanced section",
            "default": false
          }
        }
      }
    },
    "positionalParams": {
      "type": "array",
      "description": "Legacy: Positional parameters (use ports.inputs with positional=true instead)",
      "items": {"type": "string"},
      "deprecated": true
    },
    "paramMapping": {
      "type": "object",
      "description": "Legacy: Parameter mapping (use parameters instead)",
      "deprecated": true
    },
    "output": {
      "type": "object",
      "description": "Output path configuration",
      "properties": {
        "flagSupported": {
          "type": "boolean",
          "description": "Whether tool supports -o output flag",
          "default": false
        },
        "flag": {
          "type": "string",
          "description": "Output flag (e.g., '-o', '--output')"
        },
        "flagValue": {
          "type": "string",
          "description": "Fixed output value (e.g., '.' for msconvert)"
        }
      }
    },
    "outputFlagSupported": {
      "type": "boolean",
      "description": "Legacy: Use output.flagSupported instead",
      "deprecated": true
    },
    "outputFlag": {
      "type": "string",
      "description": "Legacy: Use output.flag instead",
      "deprecated": true
    },
    "toolPath": {
      "type": "string",
      "description": "Legacy: Use command.executable instead",
      "deprecated": true
    },
    "tool_type": {
      "type": "string",
      "description": "Legacy: Use executionMode instead",
      "deprecated": true
    }
  }
}
