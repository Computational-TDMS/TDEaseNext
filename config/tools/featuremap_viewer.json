{
  "id": "featuremap_viewer",
  "name": "Feature Map Viewer",
  "version": "1.0.0",
  "description": "Interactive visualization tool for LC-MS feature maps",
  "executionMode": "interactive",
  "defaultMapping": {
    "x": "mz",
    "y": "rt",
    "color": "intensity",
    "size": "charge",
    "label": "feature_id"
  },
  "ports": {
    "inputs": [
      {
        "id": "feature_data",
        "name": "Feature Data",
        "dataType": "feature",
        "required": true,
        "accept": ["feature", "ms1ft"],
        "pattern": "{sample}_ms1.feature"
      }
    ],
    "outputs": []
  },
  "parameters": {
    "plot_type": {
      "type": "choice",
      "label": "Plot Type",
      "description": "Type of visualization plot",
      "choices": ["scatter", "heatmap", "contour"],
      "default": "scatter"
    },
    "color_scale": {
      "type": "choice",
      "label": "Color Scale",
      "description": "Color scale for visualization",
      "choices": ["viridis", "plasma", "inferno", "magma", "cividis"],
      "default": "viridis"
    },
    "show_labels": {
      "type": "boolean",
      "label": "Show Labels",
      "description": "Show feature labels on plot",
      "default": false
    },
    "max_features": {
      "type": "value",
      "label": "Max Features",
      "description": "Maximum number of features to display",
      "default": "1000"
    }
  }
}
