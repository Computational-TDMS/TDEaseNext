{
  "id": "featuremap_viewer",
  "name": "Feature Map Viewer",
  "version": "1.1.0",
  "description": "Interactive visualization tool for LC-MS feature maps - supports both TopFD and ProMex output formats",
  "executionMode": "interactive",
  "defaultMapping": {
    "x": "rt",
    "y": "mz",
    "color": "intensity",
    "size": "charge",
    "label": "feature_id"
  },
  "ports": {
    "inputs": [
      {
        "id": "topfd_feature",
        "name": "TopFD Feature Data",
        "dataType": "ms1feature",
        "required": false,
        "accept": ["ms1feature", "feature"],
        "pattern": "{sample}_ms1.feature",
        "description": "TopFD MS1 feature output file (.ms1.feature)",
        "columnMapping": {
          "feature_id": "feature_id",
          "mz": "mz",
          "rt": "rt",
          "intensity": "intensity",
          "charge": "charge",
          "mass": "mass"
        }
      },
      {
        "id": "promex_feature",
        "name": "ProMex Feature Data",
        "dataType": "ms1ft",
        "required": false,
        "accept": ["ms1ft", "feature"],
        "pattern": "{sample}.ms1ft",
        "description": "ProMex MS1 feature output file (.ms1ft)",
        "columnMapping": {
          "feature_id": "FeatureID",
          "mz": "Mass",
          "rt": "RT",
          "intensity": "Intensity",
          "charge": "Charge",
          "mass": "Mass"
        }
      }
    ],
    "outputs": [
      {
        "id": "selection_out",
        "name": "Selection Output",
        "dataType": "selection",
        "portKind": "state-out",
        "semanticType": "state/selection_ids",
        "description": "Feature selection state propagated to downstream nodes"
      }
    ]
  },
  "parameters": {
    "plot_type": {
      "type": "choice",
      "label": "Plot Type",
      "description": "Type of visualization plot",
      "choices": ["scatter", "heatmap", "contour"],
      "default": "scatter"
    },
    "color_scale": {
      "type": "choice",
      "label": "Color Scale",
      "description": "Color scale for visualization",
      "choices": ["viridis", "plasma", "inferno", "magma", "cividis"],
      "default": "viridis"
    },
    "show_labels": {
      "type": "boolean",
      "label": "Show Labels",
      "description": "Show feature labels on plot",
      "default": false
    },
    "max_features": {
      "type": "value",
      "label": "Max Features",
      "description": "Maximum number of features to display",
      "default": "1000"
    }
  }
}
