{
  "id": "data_loader",
  "name": "Data Loader",
  "version": "1.0.0",
  "description": "Import raw data files into the workspace",
  "executionMode": "script",
  "useParamsJson": true,
  "contextHooks": {
    "enrichSampleContext": {
      "extractFrom": "params.input_sources[0]",
      "provide": {
        "raw_path": "{value}",
        "input_dir": "{parent}",
        "input_basename": "{stem}",
        "input_ext": "{suffix}",
        "input_file": "{name}"
      }
    },
    "injectParams": {
      "sample_name": "{sample_context.sample}"
    }
  },
  "command": {
    "executable": "src/nodes/data_loader.py",
    "interpreter": "python"
  },
  "ports": {
    "inputs": [
      {
        "id": "input_sources",
        "name": "Input Files",
        "dataType": "raw",
        "required": false,
        "accept": ["raw", "mzml", "wiff", "d"],
        "positional": false,
        "description": "Supplied via params when no upstream edge; binding optional for entry-point nodes"
      }
    ],
    "outputs": [
      {
        "id": "output",
        "name": "Output",
        "dataType": "raw",
        "pattern": "{sample}.{input_ext}",
        "handle": "output",
        "provides": ["raw"]
      }
    ]
  },
  "parameters": {
    "input_sources": {
      "flag": "--input",
      "type": "value",
      "label": "Input Files",
      "description": "List of input file paths (comma-separated)",
      "group": "basic",
      "required": true
    }
  },
  "output": {
    "flagSupported": true,
    "flag": "--output"
  }
}