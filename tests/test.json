{
  "metadata": {
    "id": "wf_test_full",
    "name": "TOPFD/TOPPIC + InformedProteomics 并行测试工作流",
    "version": "3.0.0",
    "description": "测试并行工作流 - TopFD+TopPIC 与 PBFGen+ProMex+MSPathFinderT 同时运行",
    "author": "TDEase",
    "created": "2026-03-02T00:00:00Z",
    "modified": "2026-03-03T00:00:00Z",
    "tags": ["test", "parallel", "topfd", "toppic", "pbfgen", "promex", "mspathfindert"]
  },
  "format_version": "2.0",
  "nodes": [
    {
      "id": "data_loader_1",
      "type": "data_loader",
      "position": { "x": 120, "y": 80 },
      "data": {
        "label": "数据加载器"
      },
      "nodeConfig": {
        "toolId": "data_loader",
        "paramValues": {
          "input_sources": ["data/raw/Sorghum-Histone0810162L20.raw"],
          "copy_strategy": "copy"
        }
      },
      "inputs": [],
      "outputs": [
        { "id": "mzml", "name": "mzML", "dataType": "mzml" }
      ]
    },
    {
      "id": "fasta_loader_1",
      "type": "fasta_loader",
      "position": { "x": 120, "y": 200 },
      "data": {
        "label": "FASTA加载器"
      },
      "nodeConfig": {
        "toolId": "fasta_loader",
        "paramValues": {
          "fasta_file": "data/fasta/UniProt_sorghum_focus1.fasta",
          "copy_strategy": "copy"
        }
      },
      "inputs": [],
      "outputs": [
        { "id": "fasta", "name": "FASTA", "dataType": "fasta" }
      ]
    },
    {
      "id": "msconvert_1",
      "type": "msconvert",
      "position": { "x": 300, "y": 80 },
      "data": {
        "label": "MSConvert"
      },
      "nodeConfig": {
        "toolId": "msconvert",
        "paramValues": {
          "format": "mzML",
          "mz_precision": "64",
          "intensity_precision": "64",
          "filters": "peakPicking true 1-"
        }
      },
      "inputs": [
        { "id": "input_files", "name": "Input Files", "dataType": "raw", "required": true }
      ],
      "outputs": [
        { "id": "mzml", "name": "mzML", "dataType": "mzml" }
      ]
    },
    {
      "id": "pbfgen_1",
      "type": "pbfgen",
      "position": { "x": 300, "y": 200 },
      "data": {
        "label": "PBFGen"
      },
      "nodeConfig": {
        "toolId": "pbfgen",
        "paramValues": {}
      },
      "inputs": [
        { "id": "input_file", "name": "Input File", "dataType": "raw", "required": true }
      ],
      "outputs": [
        { "id": "pbf", "name": "PBF File", "dataType": "pbf" }
      ]
    },
    {
      "id": "topfd_1",
      "type": "topfd",
      "position": { "x": 520, "y": 80 },
      "data": {
        "label": "TopFD"
      },
      "nodeConfig": {
        "toolId": "topfd",
        "paramValues": {
          "activation": "FILE",
          "max_charge": "30",
          "max_mass": "70000",
          "mz_error": "0.02",
          "ms_one_sn_ratio": "3",
          "ms_two_sn_ratio": "1",
          "precursor_window": "3.0",
          "ecscore_cutoff": "0.1",
          "min_scan_number": "1",
          "thread_number": "12",
          "env_cnn_cutoff": "0.0",
          "split_intensity_ratio": "2.5"
        }
      },
      "inputs": [
        { "id": "input_files", "name": "mzML Files", "dataType": "mzml", "required": true }
      ],
      "outputs": [
        { "id": "msalign", "name": "MSAlign", "dataType": "msalign" }
      ]
    },
    {
      "id": "promex_1",
      "type": "promex",
      "position": { "x": 520, "y": 200 },
      "data": {
        "label": "ProMex"
      },
      "nodeConfig": {
        "toolId": "promex",
        "paramValues": {
          "min_charge": "2",
          "max_charge": "60",
          "min_mass": "2000",
          "max_mass": "50000",
          "feature_map": true,
          "max_threads": "0"
        }
      },
      "inputs": [
        { "id": "input_file", "name": "Input File", "dataType": "pbf", "required": true }
      ],
      "outputs": [
        { "id": "ms1ft", "name": "MS1 Feature File", "dataType": "ms1ft" },
        { "id": "feature_png", "name": "Feature Heatmap", "dataType": "png" }
      ]
    },
    {
      "id": "toppic_1",
      "type": "toppic",
      "position": { "x": 800, "y": 80 },
      "data": {
        "label": "TopPIC"
      },
      "nodeConfig": {
        "toolId": "toppic",
        "paramValues": {
          "activation": "FILE",
          "n_terminal_form": "NONE,NME,NME_ACETYLATION,M_ACETYLATION",
          "proteoform_type": "COMPLETE,PREFIX,SUFFIX,INTERNAL",
          "num_shift": "1",
          "min_shift": "-500",
          "max_shift": "500",
          "variable_ptm_num": "3",
          "mass_error_tolerance": "10",
          "proteoform_error_tolerance": "1.2",
          "spectrum_cutoff_type": "EVALUE",
          "spectrum_cutoff_value": "0.01",
          "proteoform_cutoff_type": "EVALUE",
          "proteoform_cutoff_value": "0.01",
          "miscore_threshold": "0.15",
          "thread_number": "12",
          "num_combined_spectra": "1"
        }
      },
      "inputs": [
        { "id": "fasta_file", "name": "FASTA 文件", "dataType": "fasta", "required": true },
        { "id": "msalign_files", "name": "MSAlign 文件", "dataType": "msalign", "required": true }
      ],
      "outputs": [
        { "id": "proteoforms", "name": "Proteoforms TSV", "dataType": "tsv" }
      ]
    },
    {
      "id": "mspathfindert_1",
      "type": "mspathfindert",
      "position": { "x": 800, "y": 200 },
      "data": {
        "label": "MSPathFinderT"
      },
      "nodeConfig": {
        "toolId": "mspathfindert",
        "paramValues": {
          "search_mode": "1",
          "tda": "1",
          "precursor_tolerance": "10",
          "fragment_tolerance": "10",
          "min_length": "21",
          "max_length": "300",
          "min_charge": "2",
          "max_charge": "30",
          "min_frag_charge": "1",
          "max_frag_charge": "15",
          "min_mass": "3000",
          "max_mass": "50000",
          "threads": "0"
        }
      },
      "inputs": [
        { "id": "spec_file", "name": "Spectrum File", "dataType": "pbf", "required": true },
        { "id": "database_file", "name": "Database File", "dataType": "fasta", "required": true },
        { "id": "feature_file", "name": "Feature File", "dataType": "ms1ft", "required": false }
      ],
      "outputs": [
        { "id": "ict_tda", "name": "TDA Results", "dataType": "tsv" },
        { "id": "mzid", "name": "MZIdentML", "dataType": "mzid" },
        { "id": "param", "name": "Parameter File", "dataType": "param" }
      ]
    }
  ],
  "edges": [
