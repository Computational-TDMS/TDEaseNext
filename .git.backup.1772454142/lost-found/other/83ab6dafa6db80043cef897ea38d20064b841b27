"""
Base Executor Interface

This module defines the base interface that all task executors must implement.
"""

import asyncio
import time
from abc import ABC, abstractmethod
from pathlib import Path
from typing import Dict, Any, List, Optional
import logging

logger = logging.getLogger(__name__)


class ExecutionResult:
    """Result of task execution"""
    
    def __init__(self, success: bool, stdout: str = "", stderr: str = "", 
                 output_files: List[str] = None, metadata: Dict[str, Any] = None):
        self.success = success
        self.stdout = stdout
        self.stderr = stderr
        self.output_files = output_files or []
        self.metadata = metadata or {}
        self.execution_time: Optional[float] = None
        self.memory_usage: Optional[str] = None
        self.cpu_time: Optional[str] = None
    
    def to_dict(self) -> Dict[str, Any]:
        """Convert result to dictionary"""
        return {
            "success": self.success,
            "stdout": self.stdout,
            "stderr": self.stderr,
            "output_files": self.output_files,
            "metadata": self.metadata,
            "execution_time": self.execution_time,
            "memory_usage": self.memory_usage,
            "cpu_time": self.cpu_time
        }


class BaseExecutor(ABC):
    """Base class for tool executors"""
    
    def __init__(self):
        self.logger = logging.getLogger(self.__class__.__name__)
    
    @abstractmethod
    async def execute(self, node_def, context) -> ExecutionResult:
        """Execute tool with given configuration
        
        Args:
            node_def: NodeDefinition object containing execution configuration
            context: TaskContext object with execution environment
            
        Returns:
            ExecutionResult with execution outcome
        """
        pass
    
    @abstractmethod
    async def validate_config(self, node_def, config: dict) -> bool:
        """Validate configuration for this executor
        
        Args:
            node_def: NodeDefinition object
            config: Configuration dictionary to validate
            
        Returns:
            True if configuration is valid, False otherwise
        """
        pass
    
    async def _monitor_execution(self, process: asyncio.subprocess.Process, 
                               context, update_interval: float = 1.0) -> tuple[str, str]:
        """Monitor process execution and provide progress updates
        
        Args:
            process: The subprocess to monitor
            context: TaskContext for progress updates
            update_interval: How often to update progress (seconds)
            
        Returns:
            Tuple of (stdout, stderr)
        """
        start_time = time.time()
        stdout_chunks = []
        stderr_chunks = []
        
        try:
            # Read output in chunks to provide progress updates
            while True:
                try:
                    # Check if process is still running
                    if process.returncode is not None:
                        break
                    
                    # Read available output
                    try:
                        stdout_chunk = await asyncio.wait_for(
                            process.stdout.read(8192), timeout=0.1
                        )
                        if stdout_chunk:
                            stdout_chunks.append(stdout_chunk.decode('utf-8', errors='replace'))
                    except asyncio.TimeoutError:
                        pass
                    
                    try:
                        stderr_chunk = await asyncio.wait_for(
                            process.stderr.read(8192), timeout=0.1
                        )
                        if stderr_chunk:
                            stderr_chunks.append(stderr_chunk.decode('utf-8', errors='replace'))
                    except asyncio.TimeoutError:
                        pass
                    
                    # Update progress based on execution time (rough estimate)
                    elapsed_time = time.time() - start_time
                    # Simple progress estimation - can be overridden by specific executors
                    progress = min(80.0, elapsed_time * 2)  # Rough estimate
                    context.update_progress(progress)
                    
                    await asyncio.sleep(update_interval)
                    
                except Exception as e:
                    self.logger.warning(f"Error monitoring process: {e}")
                    break
            
            # Get final output
            final_stdout, final_stderr = await process.communicate()
            if final_stdout:
                stdout_chunks.append(final_stdout.decode('utf-8', errors='replace'))
            if final_stderr:
                stderr_chunks.append(final_stderr.decode('utf-8', errors='replace'))
            
        except Exception as e:
            self.logger.error(f"Error during process monitoring: {e}")
            # Try to get any remaining output
            try:
                final_stdout, final_stderr = await process.communicate()
                if final_stdout:
                    stdout_chunks.append(final_stdout.decode('utf-8', errors='replace'))
                if final_stderr:
                    stderr_chunks.append(final_stderr.decode('utf-8', errors='replace'))
            except:
                pass
        
        stdout = ''.join(stdout_chunks)
        stderr = ''.join(stderr_chunks)
        
        # Log execution details
        execution_time = time.time() - start_time
        self.logger.info(f"Process completed in {execution_time:.2f}s, return code: {process.returncode}")
        
        return stdout, stderr
    
    def _collect_output_files(self, context, output_patterns: List[str] = None) -> List[str]:
        """Collect output files from working directory
        
        Args:
            context: TaskContext with working directory
            output_patterns: List of glob patterns to match output files
            
        Returns:
            List of output file paths
        """
        output_files = []
        output_dir = context.working_dir / "output"
        
        if not output_dir.exists():
            return output_files
        
        try:
            if output_patterns:
                # Use specific patterns
                for pattern in output_patterns:
                    output_files.extend([str(f) for f in output_dir.glob(pattern)])
            else:
                # Collect all files in output directory
                output_files = [str(f) for f in output_dir.rglob("*") if f.is_file()]
            
            self.logger.info(f"Collected {len(output_files)} output files")
            
        except Exception as e:
            self.logger.error(f"Error collecting output files: {e}")
        
        return output_files
    
    def _prepare_input_files(self, context, input_data: Dict[str, Any]):
        """Prepare input files in the task's input directory
        
        Args:
            context: TaskContext with working directory
            input_data: Dictionary containing input file references
        """
        input_dir = context.working_dir / "input"
        input_dir.mkdir(exist_ok=True)
        
        for key, value in input_data.items():
            if isinstance(value, str) and Path(value).exists():
                # Copy file to input directory
                import shutil
                source_path = Path(value)
                dest_path = input_dir / source_path.name
                try:
                    shutil.copy2(source_path, dest_path)
                    self.logger.info(f"Copied input file {source_path} to {dest_path}")
                except Exception as e:
                    self.logger.error(f"Failed to copy input file {source_path}: {e}")
    
    def _render_template(self, template: str, config: Dict[str, Any], 
                        input_data: Dict[str, Any]) -> str:
        """Render template string with configuration and input data
        
        Args:
            template: Template string with placeholders
            config: Configuration parameters
            input_data: Input data references
            
        Returns:
            Rendered template string
        """
        try:
            # Simple template rendering using string format
            # For more complex templating, could use Jinja2
            context_vars = {
                **config,
                **input_data,
                'config': config,
                'input_data': input_data
            }
            
            # Handle nested template variables like {{ config.param }}
            import re
            
            def replace_var(match):
                var_path = match.group(1).strip()
                try:
                    # Handle dot notation like config.param
                    if '.' in var_path:
                        parts = var_path.split('.')
                        value = context_vars
                        for part in parts:
                            value = value[part]
                        return str(value)
                    else:
                        return str(context_vars.get(var_path, match.group(0)))
                except (KeyError, TypeError):
                    return match.group(0)  # Return original if not found
            
            # Replace {{ variable }} patterns
            rendered = re.sub(r'\{\{\s*([^}]+)\s*\}\}', replace_var, template)
            
            # Also handle simple {variable} patterns for backward compatibility
            rendered = rendered.format(**context_vars)
            
            return rendered
            
        except Exception as e:
            self.logger.error(f"Error rendering template: {e}")
            return template  # Return original template if rendering fails