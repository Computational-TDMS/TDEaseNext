@router.post("/environments/cleanup")
async def cleanup_environments(
    max_age_days: int = 30,
    max_size_gb: Optional[float] = None,
    background_tasks: BackgroundTasks,
    monitoring_service: MonitoringService = Depends(get_monitoring_service)
):
    """
    Clean up old UV environments
    
    Removes environments that haven't been used for the specified number
    of days or when total size exceeds the limit.
    """
    try:
        if max_age_days < 1 or max_age_days > 365:
            raise HTTPException(
                status_code=400,
                detail="max_age_days must be between 1 and 365"
            )
        
        if max_size_gb is not None and (max_size_gb < 0.1 or max_size_gb > 1000):
            raise HTTPException(
                status_code=400,
                detail="max_size_gb must be between 0.1 and 1000"
            )
        
        # Run cleanup in background
        def run_cleanup():
            try:
                result = monitoring_service.environment_manager.cleanup_old_environments(
                    max_age_days=max_age_days,
                    max_size_gb=max_size_gb
                )
                logger.info(f"Environment cleanup completed: {result}")
                return result
            except Exception as e:
                logger.error(f"Environment cleanup failed: {e}")
                return {"error": str(e)}
        
        background_tasks.add_task(run_cleanup)
        
        return {
            "success": True,
            "message": "Environment cleanup started",
            "parameters": {
                "max_age_days": max_age_days,
                "max_size_gb": max_size_gb
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Failed to start environment cleanup: {e}")
        raise HTTPException(
            status_code=500,
            detail=f"Failed to start environment cleanup: {str(e)}"
        )


