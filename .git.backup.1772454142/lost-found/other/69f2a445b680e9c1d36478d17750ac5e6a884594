@router.get("/alerts")
async def get_system_alerts(
    severity: Optional[str] = None,
    hours: int = 24,
    monitoring_service: MonitoringService = Depends(get_monitoring_service)
):
    """
    Get system alerts
    
    Returns system alerts based on resource usage thresholds and
    health check results.
    """
    try:
        if severity and severity not in ["warning", "critical"]:
            raise HTTPException(
                status_code=400,
                detail="Severity must be 'warning' or 'critical'"
            )
        
        # Get recent health check results
        health_result = await monitoring_service.health_checker.run_health_check()
        
        # Get resource metrics for alert analysis
        resource_summary = monitoring_service.resource_monitor.get_resource_summary()
        
        alerts = []
        
        # Check health status for alerts
        for check_name, check_result in health_result.get("checks", {}).items():
            check_status = check_result.get("status")
            if check_status in ["warning", "critical"]:
                if not severity or check_status == severity:
                    alerts.append({
                        "type": "health_check",
                        "source": check_name,
                        "severity": check_status,
                        "message": check_result.get("message", ""),
                        "timestamp": check_result.get("timestamp", health_result["timestamp"])
                    })
        
        # Check resource usage for alerts
        current_metrics = resource_summary.get("current")
        if current_metrics:
            if current_metrics.get("cpu_percent", 0) > 90:
                alerts.append({
                    "type": "resource_usage",
                    "source": "cpu",
                    "severity": "critical",
                    "message": f"High CPU usage: {current_metrics['cpu_percent']:.1f}%",
                    "timestamp": current_metrics.get("timestamp")
                })
            
            if current_metrics.get("memory_percent", 0) > 95:
                alerts.append({
                    "type": "resource_usage",
                    "source": "memory",
                    "severity": "critical",
                    "message": f"Critical memory usage: {current_metrics['memory_percent']:.1f}%",
                    "timestamp": current_metrics.get("timestamp")
                })
        
        return {
            "success": True,
            "data": {
                "alerts": alerts,
                "total_alerts": len(alerts),
                "time_period_hours": hours,
                "severity_filter": severity
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Failed to get system alerts: {e}")
        raise HTTPException(
            status_code=500,
            detail=f"Failed to get system alerts: {str(e)}"
        )


@router.get("/metrics/export")
async def export_metrics(
    format: str = "json",
    hours: int = 24,
    monitoring_service: MonitoringService = Depends(get_monitoring_service)
):
    """
    Export monitoring metrics
    
    Exports system metrics in various formats for external monitoring
    systems or analysis tools.
    """
    try:
        if format not in ["json", "csv"]:
            raise HTTPException(
                status_code=400,
                detail="Format must be 'json' or 'csv'"
            )
        
        if hours < 1 or hours > 168:  # Max 1 week
            raise HTTPException(
                status_code=400,
                detail="Hours must be between 1 and 168 (1 week)"
            )
        
        # Collect all metrics
        resource_history = monitoring_service.resource_monitor.get_metrics_history(hours)
        performance_summary = monitoring_service.task_tracker.get_performance_summary(hours)
        environment_summary = monitoring_service.environment_manager.get_environment_summary()
        
        export_data = {
            "export_timestamp": datetime.utcnow().isoformat(),
            "time_period_hours": hours,
            "resource_metrics": [m.__dict__ for m in resource_history],
            "performance_metrics": performance_summary,
            "environment_metrics": environment_summary
        }
        
        if format == "json":
            return {
                "success": True,
                "format": "json",
                "data": export_data
            }
        else:
            # For CSV format, we'd need to flatten the data structure
            # This is a simplified implementation
            return {
                "success": True,
                "format": "csv",
                "message": "CSV export not fully implemented",
                "data": export_data
            }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Failed to export metrics: {e}")
        raise HTTPException(
            status_code=500,
            detail=f"Failed to export metrics: {str(e)}"
        )