@router.get("/resources")
async def get_resource_metrics(
    hours: int = 1,
    monitoring_service: MonitoringService = Depends(get_monitoring_service)
):
    """
    Get system resource metrics
    
    Returns CPU, memory, disk, and network usage metrics for the specified
    time period.
    """
    try:
        if hours < 1 or hours > 168:  # Max 1 week
            raise HTTPException(
                status_code=400,
                detail="Hours must be between 1 and 168 (1 week)"
            )
        
        current_metrics = monitoring_service.resource_monitor.get_current_metrics()
        history = monitoring_service.resource_monitor.get_metrics_history(hours)
        summary = monitoring_service.resource_monitor.get_resource_summary()
        
        return {
            "success": True,
            "data": {
                "current": current_metrics.__dict__ if current_metrics else None,
                "history": [m.__dict__ for m in history],
                "summary": summary,
                "time_period_hours": hours
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Failed to get resource metrics: {e}")
        raise HTTPException(
            status_code=500,
            detail=f"Failed to get resource metrics: {str(e)}"
        )


