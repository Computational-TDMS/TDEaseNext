@router.post("/maintenance/run/{task_name}")
async def run_maintenance_task(
    task_name: str,
    background_tasks: BackgroundTasks,
    monitoring_service: MonitoringService = Depends(get_monitoring_service)
):
    """
    Manually run a maintenance task
    
    Triggers immediate execution of a scheduled maintenance task.
    """
    try:
        scheduler = monitoring_service.maintenance_scheduler
        
        if task_name not in scheduler.scheduled_tasks:
            raise HTTPException(
                status_code=404,
                detail=f"Maintenance task '{task_name}' not found"
            )
        
        if task_name in scheduler.running_tasks:
            raise HTTPException(
                status_code=409,
                detail=f"Maintenance task '{task_name}' is already running"
            )
        
        # Run task in background
        task_info = scheduler.scheduled_tasks[task_name]
        background_tasks.add_task(
            scheduler._run_maintenance_task,
            task_name,
            task_info
        )
        
        return {
            "success": True,
            "message": f"Maintenance task '{task_name}' started",
            "task_name": task_name
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Failed to run maintenance task: {e}")
        raise HTTPException(
            status_code=500,
            detail=f"Failed to run maintenance task: {str(e)}"
        )


