"""
UV Environment Management Service
"""
import asyncio
import hashlib
import logging
import os
import shutil
import toml
from dataclasses import dataclass, field
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Optional

from app.core.config import get_settings
from app.services.database import DatabaseService

logger = logging.getLogger(__name__)


@dataclass
class EnvironmentInfo:
    """Information about a UV environment"""
    hash: str
    path: Path
    dependencies: List[str]
    created_at: datetime
    last_used: datetime = field(default_factory=datetime.utcnow)
    is_valid: bool = True


class EnvironmentCreationError(Exception):
    """Raised when environment creation fails"""
    pass


class UVEnvironmentManager:
    """UV-based Python environment management"""
    
    def __init__(self, cache_dir: Optional[str] = None):
        settings = get_settings()
        self.cache_dir = Path(cache_dir or settings.uv_cache_dir)
        self.cache_dir.mkdir(parents=True, exist_ok=True)
        
        self.env_cache: Dict[str, EnvironmentInfo] = {}
        self.lock = asyncio.Lock()
        self.db_service = DatabaseService()
        self.logger = logger
        
        # Load existing environments from database
        asyncio.create_task(self._load_environments_from_db())
    
    async def _load_environments_from_db(self):
        """Load existing environments from database"""
        try:
            environments = await self.db_service.list_environments()
            for env in environments:
                if Path(env.path).exists():
                    self.env_cache[env.hash] = EnvironmentInfo(
                        hash=env.hash,
                        path=Path(env.path),
                        dependencies=env.dependencies,
                        created_at=env.created_at,
                        last_used=env.last_used,
                        is_valid=env.is_valid
                    )
                else:
                    # Environment path doesn't exist, mark as invalid
                    self.logger.warning(f"Environment path {env.path} not found, marking as invalid")
        except Exception as e:
            self.logger.error(f"Failed to load environments from database: {e}")
    
    def _compute_env_hash(self, dependencies: List[str]) -> str:
        """Compute deterministic hash for dependency list"""
        # Sort dependencies to ensure consistent hashing
        sorted_deps = sorted(dependencies)
        deps_str = "|".join(sorted_deps)
        return hashlib.sha256(deps_str.encode()).hexdigest()[:16]
    
    async def get_environment(self, dependencies: List[str]) -> EnvironmentInfo:
        """Get or create UV environment for dependencies"""
        env_hash = self._compute_env_hash(dependencies)
        
        async with self.lock:
            # Check cache first
            if env_hash in self.env_cache:
                env_info = self.env_cache[env_hash]
                if await self._validate_environment(env_info):
                    # Update last used time
                    env_info.last_used = datetime.utcnow()
                    return env_info
                else:
                    # Environment is invalid, remove from cache
                    del self.env_cache[env_hash]
            
            # Create new environment
            env_info = await self._create_uv_environment(env_hash, dependencies)
            self.env_cache[env_hash] = env_info
            
            # Save to database
            try:
                await self.db_service.create_environment(
                    hash=env_hash,
                    path=str(env_info.path),
                    dependencies=dependencies
                )
            except Exception as e:
                self.logger.error(f"Failed to save environment to database: {e}")
            
            return env_info
    
    async def _validate_environment(self, env_info: EnvironmentInfo) -> bool:
        """Validate that environment exists and is functional"""
        try:
            # Check if directory exists
            if not env_info.path.exists():
                self.logger.warning(f"Environment directory {env_info.path} does not exist")
                return False
            
            # Check if pyproject.toml exists
            pyproject_path = env_info.path / "pyproject.toml"
            if not pyproject_path.exists():
                self.logger.warning(f"pyproject.toml not found in {env_info.path}")
                return False
            
            # Check if .venv directory exists (created by uv sync)
            venv_path = env_info.path / ".venv"
            if not venv_path.exists():
                self.logger.warning(f"Virtual environment not found in {env_info.path}")
                return False
            
            # TODO: Could add more validation like checking if dependencies are installed
            return True
            
        except Exception as e:
            self.logger.error(f"Error validating environment {env_info.hash}: {e}")
            return False
    
    async def _create_uv_environment(self, env_hash: str, dependencies: List[str]) -> EnvironmentInfo:
        """Create new UV environment"""
        env_path = self.cache_dir / f"env_{env_hash}"
        
        try:
            # Create environment directory
            env_path.mkdir(parents=True, exist_ok=True)
            
            # Create pyproject.toml
            pyproject_config = {
                "project": {
                    "name": f"tdease-env-{env_hash}",
                    "version": "0.1.0",
                    "dependencies": dependencies,
                    "requires-python": ">=3.11"
                }
            }
            
            pyproject_path = env_path / "pyproject.toml"
            with open(pyproject_path, "w") as f:
                toml.dump(pyproject_config, f)
            
            self.logger.info(f"Creating UV environment at {env_path} with dependencies: {dependencies}")
            
            # Initialize UV project and sync dependencies
            process = await asyncio.create_subprocess_exec(
                "uv", "sync",
                cwd=str(env_path),
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE
            )
            
            stdout, stderr = await process.communicate()
            
            if process.returncode != 0:
                error_msg = f"UV sync failed: {stderr.decode()}"
                self.logger.error(error_msg)
                # Clean up failed environment
                if env_path.exists():
                    shutil.rmtree(env_path)
                raise EnvironmentCreationError(error_msg)
            
            self.logger.info(f"Successfully created UV environment {env_hash}")
            
            return EnvironmentInfo(
                hash=env_hash,
                path=env_path,
                dependencies=dependencies,
                created_at=datetime.utcnow()
            )
            
        except Exception as e:
            # Clean up on failure
            if env_path.exists():
                shutil.rmtree(env_path)
            raise EnvironmentCreationError(f"Failed to create environment: {e}")
    
    async def execute_in_environment(self, env_hash: str, script_path: str, 
                                   working_dir: Optional[Path] = None) -> tuple[str, str, int]:
        """Execute a Python script in the specified environment"""
        if env_hash not in self.env_cache:
            raise ValueError(f"Environment {env_hash} not found")
        
        env_info = self.env_cache[env_hash]
        
        # Build UV run command
        cmd = [
            "uv", "run",
            "--project", str(env_info.path),
            "python", str(script_path)
        ]
        
        self.logger.info(f"Executing script {script_path} in environment {env_hash}")
        
        # Execute command
        process = await asyncio.create_subprocess_exec(
            *cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE,
            cwd=str(working_dir) if working_dir else None
        )
        
        stdout, stderr = await process.communicate()
        
        # Update last used time
        env_info.last_used = datetime.utcnow()
        
        return stdout.decode(), stderr.decode(), process.returncode
    
    async def cleanup_stale_environments(self, max_age_days: int = 30):
        """Clean up environments that haven't been used recently"""
        cutoff_date = datetime.utcnow().timestamp() - (max_age_days * 24 * 60 * 60)
        
        environments_to_remove = []
        
        for env_hash, env_info in self.env_cache.items():
            if env_info.last_used.timestamp() < cutoff_date:
                environments_to_remove.append(env_hash)
        
        for env_hash in environments_to_remove:
            await self._remove_environment(env_hash)
        
        self.logger.info(f"Cleaned up {len(environments_to_remove)} stale environments")
    
    async def _remove_environment(self, env_hash: str):
        """Remove an environment from cache and filesystem"""
        if env_hash in self.env_cache:
            env_info = self.env_cache[env_hash]
            
            # Remove from filesystem
            if env_info.path.exists():
                try:
                    shutil.rmtree(env_info.path)
                    self.logger.info(f"Removed environment directory {env_info.path}")
                except Exception as e:
                    self.logger.error(f"Failed to remove environment directory {env_info.path}: {e}")
            
            # Remove from cache
            del self.env_cache[env_hash]
            
            self.logger.info(f"Removed environment {env_hash} from cache")
    
    def list_environments(self) -> List[EnvironmentInfo]:
        """List all cached environments"""
        return list(self.env_cache.values())
    
    async def get_environment_info(self, env_hash: str) -> Optional[EnvironmentInfo]:
        """Get information about a specific environment"""
        return self.env_cache.get(env_hash)