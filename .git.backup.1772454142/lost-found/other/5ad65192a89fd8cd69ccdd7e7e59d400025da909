**Database Debugging:**
```sql
-- Check locks
SELECT * FROM pg_locks WHERE NOT granted;

-- Check blocking queries
SELECT blocked_locks.pid AS blocked_pid,
       blocked_activity.usename AS blocked_user,
       blocking_locks.pid AS blocking_pid,
       blocking_activity.usename AS blocking_user,
       blocked_activity.query AS blocked_statement,
       blocking_activity.query AS current_statement_in_blocking_process
FROM pg_catalog.pg_locks blocked_locks
JOIN pg_catalog.pg_stat_activity blocked_activity ON blocked_activity.pid = blocked_locks.pid
JOIN pg_catalog.pg_locks blocking_locks ON blocking_locks.locktype = blocked_locks.locktype
JOIN pg_catalog.pg_stat_activity blocking_activity ON blocking_activity.pid = blocking_locks.pid
WHERE NOT blocked_locks.granted AND blocking_locks.granted;
```

### 3. Emergency Procedures

**Service Recovery:**
```bash
#!/bin/bash
# emergency_restart.sh
echo "$(date): Emergency restart initiated" >> /opt/tdease/logs/emergency.log

# Stop service gracefully
sudo systemctl stop tdease
sleep 5

# Force kill if necessary
sudo pkill -f "uvicorn main:app"

# Clear any locks
sudo rm -f /opt/tdease/*.lock

# Restart service
sudo systemctl start tdease

# Verify startup
sleep 10
curl -f http://localhost:8000/health || echo "Service failed to start"
```

**Database Recovery:**
```bash
# If database is corrupted
sudo systemctl stop tdease
sudo systemctl stop postgresql

# Restore from backup
sudo -u postgres pg_restore -d tdease_prod /opt/backups/latest_backup.sql

sudo systemctl start postgresql
sudo systemctl start tdease
```

