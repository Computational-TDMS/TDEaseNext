galaxy:
  database_connection: sqlite:///data/universe.sqlite?isolation_level=IMMEDIATE
  require_login: false  # 测试阶段：去除用户验证
  allow_user_creation: true
  admin_users: admin@example.com
  id_secret: CHANGE-ME-32-CHARS-MINIMUM
  file_path: data/files
  new_file_path: data/tmp
  tool_data_path: data/tool_data
  tool_config_file: config/tool_conf.xml
  tool_path: src/nodes  # 工具根目录路径，用于解析 tool_conf.xml 中的相对路径
  enable_beta_tool_formats: true  # 启用 JSON/YAML 工具格式支持
  job_config_file: config/job_conf.xml
  track_jobs_in_database: true
  cleanup_job: onsuccess
  debug: false
  enable_tool_shed_check: false
  # watch_tools: auto  # 可选：启用工具自动发现（需要 watchdog 库）