    async def _check_disk_space(self) -> Dict[str, Any]:
        """Check disk space availability"""
        try:
            disk = psutil.disk_usage('/')
            usage_percent = (disk.used / disk.total) * 100
            free_gb = disk.free / (1024**3)
            
            if usage_percent > 95:
                status = "critical"
                message = f"Critical disk usage: {usage_percent:.1f}%"
            elif usage_percent > 85:
                status = "warning"
                message = f"High disk usage: {usage_percent:.1f}%"
            else:
                status = "healthy"
                message = f"Disk usage normal: {usage_percent:.1f}%"
            
            return {
                "status": status,
                "message": message,
                "usage_percent": usage_percent,
                "free_gb": free_gb,
                "total_gb": disk.total / (1024**3)
            }
            
        except Exception as e:
            return {
                "status": "error",
                "message": f"Disk space check failed: {str(e)}"
            }
    
    async def _check_memory_health(self) -> Dict[str, Any]:
        """Check memory usage"""
        try:
            memory = psutil.virtual_memory()
            
            if memory.percent > 95:
                status = "critical"
                message = f"Critical memory usage: {memory.percent:.1f}%"
            elif memory.percent > 85:
                status = "warning"
                message = f"High memory usage: {memory.percent:.1f}%"
            else:
                status = "healthy"
                message = f"Memory usage normal: {memory.percent:.1f}%"
            
            return {
                "status": status,
                "message": message,
                "usage_percent": memory.percent,
                "available_gb": memory.available / (1024**3),
                "total_gb": memory.total / (1024**3)
            }
            
        except Exception as e:
            return {
                "status": "error",
                "message": f"Memory check failed: {str(e)}"
            }
    
    async def _check_cpu_health(self) -> Dict[str, Any]:
        """Check CPU usage"""
        try:
            cpu_percent = psutil.cpu_percent(interval=1)
            cpu_count = psutil.cpu_count()
            
            if cpu_percent > 90:
                status = "critical"
                message = f"Critical CPU usage: {cpu_percent:.1f}%"
            elif cpu_percent > 75:
                status = "warning"
                message = f"High CPU usage: {cpu_percent:.1f}%"
            else:
                status = "healthy"
                message = f"CPU usage normal: {cpu_percent:.1f}%"
            
            return {
                "status": status,
                "message": message,
                "usage_percent": cpu_percent,
                "cpu_count": cpu_count,
                "load_average": getattr(os, 'getloadavg', lambda: None)()
            }
            
        except Exception as e:
            return {
                "status": "error",
                "message": f"CPU check failed: {str(e)}"
            }
    
    async def _check_environments_health(self) -> Dict[str, Any]:
        """Check UV environments health"""
        try:
            env_manager = EnvironmentManager()
            environments = env_manager.scan_environments()
            
            total_size_gb = sum(env.size_mb for env in environments) / 1024
            old_environments = len([env for env in environments 
                                  if (datetime.utcnow() - env.last_used).days > 30])
            
            if total_size_gb > 10:  # > 10GB
                status = "warning"
                message = f"Large environments size: {total_size_gb:.1f}GB"
            elif old_environments > 5:
                status = "warning"
                message = f"{old_environments} environments not used in 30+ days"
            else:
                status = "healthy"
                message = f"{len(environments)} environments, {total_size_gb:.1f}GB total"
            
            return {
                "status": status,
                "message": message,
                "total_environments": len(environments),
                "total_size_gb": total_size_gb,
                "old_environments": old_environments
            }
            
        except Exception as e:
            return {
                "status": "error",
                "message": f"Environments check failed: {str(e)}"
            }
    
    async def _check_services_health(self) -> Dict[str, Any]:
        """Check critical services health"""
        try:
            # Check if critical processes are running
            services_status = {
                "uvicorn": False,
                "task_executor": False
            }
            
            for proc in psutil.process_iter(['pid', 'name', 'cmdline']):
                try:
                    cmdline = ' '.join(proc.info['cmdline'] or [])
                    if 'uvicorn' in cmdline.lower():
                        services_status["uvicorn"] = True
                    if 'task_executor' in cmdline.lower():
                        services_status["task_executor"] = True
                except (psutil.NoSuchProcess, psutil.AccessDenied):
                    continue
            
            running_services = sum(services_status.values())
            total_services = len(services_status)
            
            if running_services == total_services:
                status = "healthy"
                message = "All critical services running"
            elif running_services > 0:
                status = "warning"
                message = f"{running_services}/{total_services} services running"
            else:
                status = "critical"
                message = "No critical services detected"
            
            return {
                "status": status,
                "message": message,
                "services": services_status
            }
            
        except Exception as e:
            return {
                "status": "error",
                "message": f"Services check failed: {str(e)}"
            }


class MaintenanceScheduler:
    """Automated maintenance task scheduler"""
    
    def __init__(self):
        self.scheduled_tasks = {}
        self.running_tasks = set()
        self.task_history = []
        self.logger = logger
    
    def schedule_task(self, task_name: str, task_func, interval_hours: int, 
                     immediate: bool = False):
        """Schedule a maintenance task"""
        
        next_run = datetime.utcnow()
        if not immediate:
            next_run += timedelta(hours=interval_hours)
        
        self.scheduled_tasks[task_name] = {
            "function": task_func,
            "interval_hours": interval_hours,
            "next_run": next_run,
            "last_run": None,
            "run_count": 0,
            "last_result": None
        }
        
        self.logger.info(f"Scheduled maintenance task '{task_name}' to run every {interval_hours} hours")
    
    async def run_scheduler(self):
        """Run the maintenance scheduler"""
        self.logger.info("Starting maintenance scheduler")
        
        while True:
            try:
                await self._check_and_run_tasks()
                await asyncio.sleep(300)  # Check every 5 minutes
                
            except Exception as e:
                self.logger.error(f"Maintenance scheduler error: {e}")
                await asyncio.sleep(300)
    
    async def _check_and_run_tasks(self):
        """Check and run due maintenance tasks"""
        now = datetime.utcnow()
        
        for task_name, task_info in self.scheduled_tasks.items():
            if now >= task_info["next_run"] and task_name not in self.running_tasks:
                # Run task in background
                asyncio.create_task(self._run_maintenance_task(task_name, task_info))
    
    async def _run_maintenance_task(self, task_name: str, task_info: Dict[str, Any]):
        """Run a single maintenance task"""
        self.running_tasks.add(task_name)
        start_time = datetime.utcnow()
        
        try:
            self.logger.info(f"Running maintenance task: {task_name}")
            
            # Run the task function
            if asyncio.iscoroutinefunction(task_info["function"]):
                result = await task_info["function"]()
            else:
                result = task_info["function"]()
            
            # Update task info
            task_info["last_run"] = start_time
            task_info["run_count"] += 1
            task_info["last_result"] = result
            task_info["next_run"] = start_time + timedelta(hours=task_info["interval_hours"])
            
            # Record in history
            duration = (datetime.utcnow() - start_time).total_seconds()
            self.task_history.append({
                "task_name": task_name,
                "start_time": start_time,
                "duration_seconds": duration,
                "status": "completed",
                "result": result
            })
            
            self.logger.info(f"Completed maintenance task '{task_name}' in {duration:.2f}s")
            
        except Exception as e:
            # Record failure
            duration = (datetime.utcnow() - start_time).total_seconds()
            self.task_history.append({
                "task_name": task_name,
                "start_time": start_time,
                "duration_seconds": duration,
                "status": "failed",
                "error": str(e)
            })
            
            self.logger.error(f"Maintenance task '{task_name}' failed: {e}")
            
            # Still schedule next run
            task_info["next_run"] = start_time + timedelta(hours=task_info["interval_hours"])
        
        finally:
            self.running_tasks.discard(task_name)
    
    def get_scheduler_status(self) -> Dict[str, Any]:
        """Get maintenance scheduler status"""
        now = datetime.utcnow()
        
        task_status = {}
        for task_name, task_info in self.scheduled_tasks.items():
            task_status[task_name] = {
                "next_run": task_info["next_run"].isoformat(),
                "last_run": task_info["last_run"].isoformat() if task_info["last_run"] else None,
                "run_count": task_info["run_count"],
                "currently_running": task_name in self.running_tasks,
                "interval_hours": task_info["interval_hours"]
            }
        
        # Recent task history
        recent_history = [h for h in self.task_history 
                         if (now - h["start_time"]).days < 7]
        
        return {
            "scheduled_tasks": task_status,
            "currently_running": list(self.running_tasks),
            "recent_history": recent_history[-20:],  # Last 20 runs
            "total_scheduled": len(self.scheduled_tasks)
        }


class MonitoringService:
    """Main monitoring service that coordinates all monitoring components"""
    
    def __init__(self):
        self.resource_monitor = ResourceMonitor()
        self.task_tracker = TaskPerformanceTracker()
        self.environment_manager = EnvironmentManager()
        self.health_checker = SystemHealthChecker()
        self.maintenance_scheduler = MaintenanceScheduler()
        self.logger = logger
        self._setup_maintenance_tasks()
    
    def _setup_maintenance_tasks(self):
        """Setup default maintenance tasks"""
        
        # Environment cleanup every 24 hours
        self.maintenance_scheduler.schedule_task(
            "environment_cleanup",
            lambda: self.environment_manager.cleanup_old_environments(max_age_days=30),
            interval_hours=24
        )
        
        # System health check every 6 hours
        self.maintenance_scheduler.schedule_task(
            "health_check",
            self.health_checker.run_health_check,
            interval_hours=6
        )
        
        # Temporary file cleanup every 12 hours
        self.maintenance_scheduler.schedule_task(
            "temp_cleanup",
            self._cleanup_temp_files,
            interval_hours=12
        )
    
    async def start_monitoring(self):
        """Start all monitoring services"""
        self.logger.info("Starting monitoring services")
        
        # Start resource monitoring
        asyncio.create_task(self.resource_monitor.start_monitoring())
        
        # Start maintenance scheduler
        asyncio.create_task(self.maintenance_scheduler.run_scheduler())
        
        self.logger.info("All monitoring services started")
    
    def stop_monitoring(self):
        """Stop all monitoring services"""
        self.logger.info("Stopping monitoring services")
        self.resource_monitor.stop_monitoring()
    
    def _cleanup_temp_files(self) -> Dict[str, Any]:
        """Clean up temporary files"""
        temp_dirs = [
            Path("./temp"),
            Path("./test_environments"),
            Path("/tmp/tdease") if Path("/tmp").exists() else None
        ]
        
        cleanup_results = {
            "directories_cleaned": 0,
            "files_removed": 0,
            "space_freed_mb": 0,
            "errors": []
        }
        
        for temp_dir in temp_dirs:
            if temp_dir and temp_dir.exists():
                try:
                    # Remove files older than 24 hours
                    cutoff_time = time.time() - (24 * 3600)
                    
                    for file_path in temp_dir.rglob("*"):
                        if file_path.is_file():
                            try:
                                if file_path.stat().st_mtime < cutoff_time:
                                    file_size = file_path.stat().st_size
                                    file_path.unlink()
                                    cleanup_results["files_removed"] += 1
                                    cleanup_results["space_freed_mb"] += file_size / (1024 * 1024)
                            except Exception as e:
                                cleanup_results["errors"].append(f"Could not remove {file_path}: {e}")
                    
                    cleanup_results["directories_cleaned"] += 1
                    
                except Exception as e:
                    cleanup_results["errors"].append(f"Could not clean {temp_dir}: {e}")
        
        self.logger.info(f"Temp cleanup: removed {cleanup_results['files_removed']} files, "
                        f"freed {cleanup_results['space_freed_mb']:.1f}MB")
        
        return cleanup_results
    
    def get_comprehensive_status(self) -> Dict[str, Any]:
        """Get comprehensive system status"""
        return {
            "timestamp": datetime.utcnow().isoformat(),
            "resource_monitoring": self.resource_monitor.get_resource_summary(),
            "task_performance": self.task_tracker.get_performance_summary(),
            "environment_status": self.environment_manager.get_environment_summary(),
            "maintenance_scheduler": self.maintenance_scheduler.get_scheduler_status()
        }


