    def __init__(self):
        self.logger = logger
        self.health_checks = {
            'database': self._check_database_health,
            'disk_space': self._check_disk_space,
            'memory': self._check_memory_health,
            'cpu': self._check_cpu_health,
            'environments': self._check_environments_health,
            'services': self._check_services_health
        }
    
    async def run_health_check(self, check_name: Optional[str] = None) -> Dict[str, Any]:
        """Run health checks"""
        
        if check_name and check_name not in self.health_checks:
            return {"error": f"Unknown health check: {check_name}"}
        
        checks_to_run = {check_name: self.health_checks[check_name]} if check_name else self.health_checks
        
        results = {
            "timestamp": datetime.utcnow().isoformat(),
            "overall_status": "healthy",
            "checks": {}
        }
        
        for name, check_func in checks_to_run.items():
            try:
                check_result = await check_func()
                results["checks"][name] = check_result
                
                # Update overall status
                if check_result.get("status") == "critical":
                    results["overall_status"] = "critical"
                elif check_result.get("status") == "warning" and results["overall_status"] == "healthy":
                    results["overall_status"] = "warning"
                    
            except Exception as e:
                results["checks"][name] = {
                    "status": "error",
                    "message": f"Health check failed: {str(e)}",
                    "timestamp": datetime.utcnow().isoformat()
                }
                results["overall_status"] = "critical"
        
        return results
    
    async def _check_database_health(self) -> Dict[str, Any]:
