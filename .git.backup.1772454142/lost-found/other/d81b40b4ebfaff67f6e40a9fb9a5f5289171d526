"""
Database service for managing database operations
"""
import logging
from typing import Optional, List
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, update, delete, func
from sqlalchemy.orm import selectinload
from sqlalchemy.exc import IntegrityError, SQLAlchemyError
from datetime import datetime, timedelta

from app.core.database import get_db_session
from app.models import Project, Workflow, Task, Environment

logger = logging.getLogger(__name__)


class DatabaseService:
    """Service for database operations with comprehensive CRUD functionality"""
    
    def __init__(self):
        self.logger = logger
    
    # Project operations
    async def create_project(self, name: str, description: Optional[str] = None, 
                           path: Optional[str] = None) -> Project:
        """Create a new project"""
        try:
            async for session in get_db_session():
                project = Project(
                    name=name,
                    description=description,
                    path=path or f"./projects/{name.lower().replace(' ', '_')}"
                )
                session.add(project)
                await session.commit()
                await session.refresh(project)
                self.logger.info(f"Created project: {project.id} - {project.name}")
                return project
        except IntegrityError as e:
            self.logger.error(f"Failed to create project due to integrity error: {e}")
            raise
        except SQLAlchemyError as e:
            self.logger.error(f"Database error creating project: {e}")
            raise
    
    async def get_project(self, project_id: str) -> Optional[Project]:
        """Get project by ID with relationships"""
        try:
            async for session in get_db_session():
                result = await session.execute(
                    select(Project)
                    .options(
                        selectinload(Project.workflows),
                        selectinload(Project.tasks)
                    )
                    .where(Project.id == project_id)
                )
                return result.scalar_one_or_none()
        except SQLAlchemyError as e:
            self.logger.error(f"Database error getting project {project_id}: {e}")
            raise
    
    async def list_projects(self, limit: Optional[int] = None, 
                          offset: Optional[int] = None) -> List[Project]:
        """List all projects with optional pagination"""
        try:
            async for session in get_db_session():
                query = select(Project).order_by(Project.created_at.desc())
                if limit:
                    query = query.limit(limit)
                if offset:
                    query = query.offset(offset)
                
                result = await session.execute(query)
                return list(result.scalars().all())
        except SQLAlchemyError as e:
            self.logger.error(f"Database error listing projects: {e}")
            raise
    
    async def update_project(self, project_id: str, name: Optional[str] = None,
                           description: Optional[str] = None, 
                           path: Optional[str] = None) -> Optional[Project]:
        """Update project details"""
        try:
            async for session in get_db_session():
                project = await session.get(Project, project_id)
                if not project:
                    return None
                
                if name is not None:
                    project.name = name
                if description is not None:
                    project.description = description
                if path is not None:
                    project.path = path
                
                project.updated_at = datetime.utcnow()
                await session.commit()
                await session.refresh(project)
                self.logger.info(f"Updated project: {project.id}")
                return project
        except SQLAlchemyError as e:
            self.logger.error(f"Database error updating project {project_id}: {e}")
            raise
    
    async def delete_project(self, project_id: str) -> bool:
        """Delete project and all related data"""
        try:
            async for session in get_db_session():
                project = await session.get(Project, project_id)
                if not project:
                    return False
                
                await session.delete(project)
                await session.commit()
                self.logger.info(f"Deleted project: {project_id}")
                return True
        except SQLAlchemyError as e:
            self.logger.error(f"Database error deleting project {project_id}: {e}")
            raise
    
