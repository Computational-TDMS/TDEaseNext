    async def update_task_status(self, task_id: str, status: str, 
                               result: Optional[dict] = None,
                               error_message: Optional[str] = None,
                               started_at: Optional[datetime] = None,
                               completed_at: Optional[datetime] = None,
                               cpu_time: Optional[str] = None,
                               memory_peak: Optional[str] = None) -> bool:
        """Update task status and execution details"""
        try:
            async for session in get_db_session():
                update_values = {
                    "status": status,
                    "updated_at": datetime.utcnow()
                }
                
                if result is not None:
                    update_values["result"] = result
                if error_message is not None:
                    update_values["error_message"] = error_message
                if started_at is not None:
                    update_values["started_at"] = started_at
                if completed_at is not None:
                    update_values["completed_at"] = completed_at
                if cpu_time is not None:
                    update_values["cpu_time"] = cpu_time
                if memory_peak is not None:
                    update_values["memory_peak"] = memory_peak
                
                stmt = update(Task).where(Task.id == task_id).values(**update_values)
                result = await session.execute(stmt)
                await session.commit()
                
                if result.rowcount > 0:
                    self.logger.info(f"Updated task {task_id} status to {status}")
                    return True
                return False
        except SQLAlchemyError as e:
            self.logger.error(f"Database error updating task {task_id}: {e}")
            raise
    
    # Environment operations
    async def create_environment(self, hash: str, path: str, 
                               dependencies: List[str]) -> Environment:
        """Create a new environment record"""
        try:
            async for session in get_db_session():
                environment = Environment(
                    hash=hash,
                    path=path,
                    dependencies=dependencies
                )
                session.add(environment)
                await session.commit()
                await session.refresh(environment)
                self.logger.info(f"Created environment: {environment.id} - {environment.hash}")
                return environment
        except IntegrityError as e:
            # Environment with this hash already exists
            self.logger.warning(f"Environment with hash {hash} already exists")
            return await self.get_environment_by_hash(hash)
        except SQLAlchemyError as e:
            self.logger.error(f"Database error creating environment: {e}")
            raise
    
    async def get_environment_by_hash(self, hash: str) -> Optional[Environment]:
        """Get environment by hash"""
        try:
            async for session in get_db_session():
                result = await session.execute(
                    select(Environment).where(Environment.hash == hash)
                )
                return result.scalar_one_or_none()
        except SQLAlchemyError as e:
            self.logger.error(f"Database error getting environment by hash {hash}: {e}")
            raise
    
    async def list_environments(self, valid_only: bool = True) -> List[Environment]:
        """List all environments, optionally filter by validity"""
        try:
            async for session in get_db_session():
                query = select(Environment).order_by(Environment.last_used.desc())
                if valid_only:
                    query = query.where(Environment.is_valid == True)
                
                result = await session.execute(query)
                return list(result.scalars().all())
        except SQLAlchemyError as e:
            self.logger.error(f"Database error listing environments: {e}")
            raise
    
    async def update_environment_last_used(self, hash: str) -> bool:
        """Update environment last used timestamp"""
        try:
            async for session in get_db_session():
                stmt = (
                    update(Environment)
                    .where(Environment.hash == hash)
                    .values(
                        last_used=datetime.utcnow(),
                        updated_at=datetime.utcnow()
                    )
                )
                result = await session.execute(stmt)
                await session.commit()
                return result.rowcount > 0
        except SQLAlchemyError as e:
            self.logger.error(f"Database error updating environment {hash}: {e}")
            raise
    
    async def mark_environment_invalid(self, hash: str) -> bool:
        """Mark environment as invalid"""
        try:
            async for session in get_db_session():
                stmt = (
                    update(Environment)
                    .where(Environment.hash == hash)
                    .values(
                        is_valid=False,
                        updated_at=datetime.utcnow()
                    )
                )
                result = await session.execute(stmt)
                await session.commit()
                return result.rowcount > 0
        except SQLAlchemyError as e:
            self.logger.error(f"Database error marking environment {hash} invalid: {e}")
            raise
    
    async def cleanup_old_environments(self, days_old: int = 30) -> int:
        """Clean up environments older than specified days"""
        try:
            async for session in get_db_session():
                cutoff_date = datetime.utcnow() - timedelta(days=days_old)
                stmt = (
                    delete(Environment)
                    .where(Environment.last_used < cutoff_date)
                    .where(Environment.is_valid == False)
                )
                result = await session.execute(stmt)
                await session.commit()
                self.logger.info(f"Cleaned up {result.rowcount} old environments")
                return result.rowcount
        except SQLAlchemyError as e:
            self.logger.error(f"Database error cleaning up environments: {e}")
            raise
    
    # Statistics and monitoring
    async def get_project_stats(self, project_id: str) -> dict:
        """Get statistics for a project"""
        try:
            async for session in get_db_session():
                # Count workflows
                workflow_count = await session.execute(
                    select(func.count(Workflow.id)).where(Workflow.project_id == project_id)
                )
                
                # Count tasks by status
                task_stats = await session.execute(
                    select(Task.status, func.count(Task.id))
                    .where(Task.project_id == project_id)
                    .group_by(Task.status)
                )
                
                return {
                    "workflow_count": workflow_count.scalar(),
                    "task_stats": dict(task_stats.fetchall())
                }
        except SQLAlchemyError as e:
            self.logger.error(f"Database error getting project stats {project_id}: {e}")
            raise