"""
Node configuration management and validation
"""
import logging
from typing import Dict, Any, List, Optional, Union
from pathlib import Path
import json
import yaml
from jinja2 import Template, Environment as JinjaEnv, BaseLoader

from app.models.node import NodeDefinition, ParameterType

logger = logging.getLogger(__name__)


class NodeConfigManager:
    """Manager for node configuration and template rendering"""
    
    def __init__(self):
        self.jinja_env = JinjaEnv(loader=BaseLoader())
        self.logger = logger
    
    def validate_config(self, node_def: NodeDefinition, config: Dict[str, Any]) -> Dict[str, List[str]]:
        """Validate configuration against node definition"""
        errors = {}
        
        # Use node's built-in validation
        node_errors = node_def.validate_config(config)
        if node_errors:
            errors.update(node_errors)
        
        # Additional validation for file paths
        for param in node_def.parameters:
            if param.name in config:
                value = config[param.name]
                
                if param.type == ParameterType.FILE:
                    if not self._validate_file_path(value, param.file_extensions):
                        if "invalid_files" not in errors:
                            errors["invalid_files"] = []
                        errors["invalid_files"].append(f"{param.name}: {value}")
                
                elif param.type == ParameterType.DIRECTORY:
                    if not self._validate_directory_path(value):
                        if "invalid_directories" not in errors:
                            errors["invalid_directories"] = []
                        errors["invalid_directories"].append(f"{param.name}: {value}")
        
        return errors
    
    def merge_with_defaults(self, node_def: NodeDefinition, config: Dict[str, Any]) -> Dict[str, Any]:
        """Merge user config with default values"""
        merged_config = node_def.get_default_config()
        merged_config.update(config)
        return merged_config
    
    def render_command_template(self, node_def: NodeDefinition, config: Dict[str, Any], 
                              input_data: Dict[str, Any], working_dir: Path) -> str:
        """Render command template with configuration and input data"""
        if not node_def.command_template:
            raise ValueError(f"Node {node_def.id} has no command template")
        
        # Prepare template context
        context = {
            "config": config,
            "input_data": input_data,
            "working_dir": str(working_dir),
            "input_dir": str(working_dir / "input"),
            "output_dir": str(working_dir / "output"),
            "temp_dir": str(working_dir / "temp")
        }
        
        # Add individual config parameters to root context for convenience
        context.update(config)
        
        try:
            template = self.jinja_env.from_string(node_def.command_template)
            return template.render(**context)
        except Exception as e:
            logger.error(f"Error rendering command template for {node_def.id}: {e}")
            raise
    
    def render_script_template(self, node_def: NodeDefinition, config: Dict[str, Any],
                             input_data: Dict[str, Any], working_dir: Path) -> str:
        """Render script template with configuration and input data"""
        if not node_def.script_template:
            raise ValueError(f"Node {node_def.id} has no script template")
        
        # Prepare template context
        context = {
            "config": config,
            "input_data": input_data,
            "working_dir": str(working_dir),
            "input_dir": str(working_dir / "input"),
            "output_dir": str(working_dir / "output"),
            "temp_dir": str(working_dir / "temp")
        }
        
        try:
            template = self.jinja_env.from_string(node_def.script_template)
            return template.render(**context)
        except Exception as e:
            logger.error(f"Error rendering script template for {node_def.id}: {e}")
            raise
    
    def prepare_execution_context(self, node_def: NodeDefinition, config: Dict[str, Any],
                                input_data: Dict[str, Any], working_dir: Path) -> Dict[str, Any]:
        """Prepare complete execution context for a node"""
        # Validate configuration
        validation_errors = self.validate_config(node_def, config)
        if validation_errors:
            raise ValueError(f"Configuration validation failed: {validation_errors}")
        
        # Merge with defaults
        merged_config = self.merge_with_defaults(node_def, config)
        
        # Create working directories
        self._create_working_directories(working_dir)
        
        # Prepare execution context
        context = {
            "node_id": node_def.id,
            "node_name": node_def.name,
            "execution_type": node_def.execution_type,
            "config": merged_config,
            "input_data": input_data,
            "working_dir": working_dir,
            "dependencies": node_def.dependencies,
            "environment_vars": node_def.environment_vars or {}
        }
        
        # Add execution-specific context
        if node_def.execution_type.value == "cli":
            context["command"] = self.render_command_template(
                node_def, merged_config, input_data, working_dir
            )
        elif node_def.execution_type.value == "python":
            if node_def.script_template:
                context["script_content"] = self.render_script_template(
                    node_def, merged_config, input_data, working_dir
                )
            else:
                context["script_path"] = node_def.script_path
        elif node_def.execution_type.value == "docker":
            context["docker_image"] = node_def.docker_image
            context["docker_command"] = node_def.docker_command
            context["docker_volumes"] = node_def.docker_volumes or {}
        elif node_def.execution_type.value == "cloud":
            context["cloud_service"] = node_def.cloud_service
            context["cloud_config"] = node_def.cloud_config or {}
        
        return context
    
    def save_config_to_file(self, config: Dict[str, Any], file_path: str, 
                           format: str = "json") -> bool:
        """Save configuration to file"""
        try:
            path = Path(file_path)
            path.parent.mkdir(parents=True, exist_ok=True)
            
            if format.lower() == "json":
                with open(path, 'w') as f:
                    json.dump(config, f, indent=2)
            elif format.lower() in ["yaml", "yml"]:
                with open(path, 'w') as f:
                    yaml.dump(config, f, default_flow_style=False)
            else:
                raise ValueError(f"Unsupported format: {format}")
            
            logger.info(f"Saved configuration to {file_path}")
            return True
            
        except Exception as e:
            logger.error(f"Error saving configuration to {file_path}: {e}")
            return False
    
    def load_config_from_file(self, file_path: str) -> Optional[Dict[str, Any]]:
        """Load configuration from file"""
        try:
            path = Path(file_path)
            if not path.exists():
                logger.warning(f"Configuration file not found: {file_path}")
                return None
            
            with open(path, 'r') as f:
                if path.suffix.lower() == ".json":
                    return json.load(f)
                elif path.suffix.lower() in [".yaml", ".yml"]:
                    return yaml.safe_load(f)
                else:
                    # Try to detect format from content
                    content = f.read()
                    try:
                        return json.loads(content)
                    except json.JSONDecodeError:
                        return yaml.safe_load(content)
        
        except Exception as e:
            logger.error(f"Error loading configuration from {file_path}: {e}")
            return None
    
    def generate_config_template(self, node_def: NodeDefinition) -> Dict[str, Any]:
        """Generate configuration template with default values and comments"""
        template = {}
        
        for param in node_def.parameters:
            value = param.default
            
            # Add type hints as comments (for YAML)
            comment = f"{param.description}"
            if param.type != ParameterType.STRING:
                comment += f" (type: {param.type.value})"
            if param.required:
                comment += " [REQUIRED]"
            if param.options:
                comment += f" (options: {', '.join(param.options)})"
            
            template[param.name] = {
                "value": value,
                "description": comment,
                "type": param.type.value,
                "required": param.required
            }
        
        return template
    
    def _validate_file_path(self, file_path: str, allowed_extensions: Optional[List[str]] = None) -> bool:
        """Validate file path and extension"""
        try:
            path = Path(file_path)
            
            # Check if file exists (for absolute paths) or is a valid relative path
            if path.is_absolute() and not path.exists():
                return False
            
            # Check file extension
            if allowed_extensions:
                return path.suffix.lower() in [ext.lower() for ext in allowed_extensions]
            
            return True
        except Exception:
            return False
    
    def _validate_directory_path(self, dir_path: str) -> bool:
        """Validate directory path"""
        try:
            path = Path(dir_path)
            
            # Check if directory exists (for absolute paths) or is a valid relative path
            if path.is_absolute() and not path.exists():
                return False
            
            return True
        except Exception:
            return False
    
    def _create_working_directories(self, working_dir: Path):
        """Create necessary working directories"""
        directories = ["input", "output", "temp", "logs"]
        
        for dir_name in directories:
            dir_path = working_dir / dir_name
            dir_path.mkdir(parents=True, exist_ok=True)


class NodeConfigValidator:
    """Specialized validator for node configurations"""
    
    def __init__(self):
        self.logger = logger
    
    def validate_mass_spec_file(self, file_path: str) -> Dict[str, Any]:
        """Validate mass spectrometry file"""
        result = {
            "valid": False,
            "format": None,
            "size": 0,
            "errors": []
        }
        
        try:
            path = Path(file_path)
            
            if not path.exists():
                result["errors"].append("File does not exist")
                return result
            
            # Check file size
            result["size"] = path.stat().st_size
            
            # Detect format from extension
            ext = path.suffix.lower()
            if ext in [".mzml", ".mzxml"]:
                result["format"] = ext[1:]  # Remove dot
                result["valid"] = self._validate_xml_format(path)
            elif ext == ".mgf":
                result["format"] = "mgf"
                result["valid"] = self._validate_mgf_format(path)
            elif ext == ".raw":
                result["format"] = "raw"
                result["valid"] = True  # Can't validate proprietary format
            else:
                result["errors"].append(f"Unsupported file format: {ext}")
            
        except Exception as e:
            result["errors"].append(str(e))
        
        return result
    
    def _validate_xml_format(self, file_path: Path) -> bool:
        """Validate XML-based mass spec formats (mzML, mzXML)"""
        try:
            import xml.etree.ElementTree as ET
            
            # Try to parse XML
            tree = ET.parse(file_path)
            root = tree.getroot()
            
            # Check for expected root elements
            if file_path.suffix.lower() == ".mzml":
                return "mzML" in root.tag
            elif file_path.suffix.lower() == ".mzxml":
                return "mzXML" in root.tag
            
            return False
        except Exception:
            return False
    
    def _validate_mgf_format(self, file_path: Path) -> bool:
        """Validate MGF format"""
        try:
            with open(file_path, 'r') as f:
                # Read first few lines to check format
                lines = [f.readline().strip() for _ in range(10)]
                
            # Look for MGF markers
            has_begin_ions = any("BEGIN IONS" in line for line in lines)
            return has_begin_ions
        except Exception:
            return False