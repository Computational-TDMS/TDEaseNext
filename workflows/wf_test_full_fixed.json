    {
      "id": "topfd_1",
      "type": "topfd",
      "position": {
        "x": 520,
        "y": 80
      },
      "data": {
        "label": "TopFD"
      },
      "nodeConfig": {
        "toolId": "topfd",
        "paramValues": {
          "activation": "FILE",
          "max_charge": "30",
          "max_mass": "70000",
          "mz_error": "0.02",
          "ms_one_sn_ratio": "3",
          "ms_two_sn_ratio": "1",
          "precursor_window": "3.0",
          "ecscore_cutoff": "0.1",
          "min_scan_number": "1",
          "thread_number": "12",
          "env_cnn_cutoff": "0.0",
          "split_intensity_ratio": "2.5"
        }
      },
      "inputs": [
        {
          "id": "input_files",
          "name": "mzML Files",
          "dataType": "mzml",
          "required": true
        }
      ],
      "outputs": [
        {
          "id": "ms1feature",
          "name": "MS1 Feature File",
          "dataType": "feature",
          "description": "LC-MS feature file containing MS1 features"
        },
        {
          "id": "ms2feature",
          "name": "MS2 Feature File",
          "dataType": "feature",
          "description": "MS/MS scan IDs and their corresponding LC-MS feature IDs"
        },
        {
          "id": "feature_xml",
          "name": "Feature XML",
          "dataType": "xml",
          "description": "LC-MS features in XML format"
        },
        {
          "id": "ms1_msalign",
          "name": "MS1 MSAlign",
          "dataType": "msalign",
          "description": "Deconvoluted MS1 spectra"
        },
        {
          "id": "ms2_msalign",
          "name": "MS2 MSAlign",
          "dataType": "msalign",
          "description": "Deconvoluted MS/MS spectra for TopPIC"
        },
        {
          "id": "html_folder",
          "name": "HTML Visualization",
          "dataType": "html",
          "description": "JavaScript files for MS1 and MS/MS spectral visualization"
        }
      ]
    },
    {
