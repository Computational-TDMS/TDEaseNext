      "type": "promex",
      "position": {
        "x": 520,
        "y": 200
      },
      "data": {
        "label": "ProMex"
      },
      "nodeConfig": {
        "toolId": "promex",
        "paramValues": {
          "min_charge": "2",
          "max_charge": "60",
          "min_mass": "2000",
          "max_mass": "50000",
          "feature_map": true,
          "max_threads": "0"
        }
      },
      "inputs": [
        {
          "id": "input_file",
          "name": "Input File",
          "dataType": "pbf",
          "required": true
