    },
    {
      "id": "toppic_1",
      "type": "toppic",
      "position": {
        "x": 800,
        "y": 80
      },
      "data": {
        "label": "TopPIC"
      },
      "nodeConfig": {
        "toolId": "toppic",
        "paramValues": {
          "activation": "FILE",
          "n_terminal_form": "NONE,NME,NME_ACETYLATION,M_ACETYLATION",
          "proteoform_type": "COMPLETE,PREFIX,SUFFIX,INTERNAL",
          "num_shift": "1",
          "min_shift": "-500",
          "max_shift": "500",
          "variable_ptm_num": "3",
          "mass_error_tolerance": "10",
          "proteoform_error_tolerance": "1.2",
          "spectrum_cutoff_type": "EVALUE",
          "spectrum_cutoff_value": "0.01",
          "proteoform_cutoff_type": "EVALUE",
          "proteoform_cutoff_value": "0.01",
          "miscore_threshold": "0.15",
          "thread_number": "12",
          "num_combined_spectra": "1"
        }
      },
      "inputs": [
        {
          "id": "fasta_file",
          "name": "FASTA 文件",
          "dataType": "fasta",
          "required": true
        },
        {
          "id": "msalign_files",
          "name": "MSAlign 文件",
          "dataType": "msalign",
          "required": true
        }
      ],
      "outputs": [
        {
          "id": "prsm",
          "name": "PrSM TSV (All Proteins)",
          "dataType": "tsv",
          "description": "Proteoform spectrum-matches with E-value/FDR cutoff (all proteins reported)"
        },
        {
          "id": "prsm_single",
          "name": "PrSM TSV (Single Protein)",
          "dataType": "tsv",
          "description": "Proteoform spectrum-matches with E-value/FDR cutoff (single protein reported)"
        },
        {
          "id": "proteoforms",
          "name": "Proteoforms TSV (All Proteins)",
          "dataType": "tsv",
          "description": "Identified proteoforms with E-value/proteoform-level FDR cutoff (all proteins reported)"
        },
        {
          "id": "proteoforms_single",
          "name": "Proteoforms TSV (Single Protein)",
          "dataType": "tsv",
          "description": "Identified proteoforms with E-value/proteoform-level FDR cutoff (single protein reported)"
        },
        {
          "id": "proteoform_xml",
          "name": "Proteoform XML",
          "dataType": "xml",
          "description": "Identified proteoforms in XML format with E-value/FDR cutoff"
        },
        {
          "id": "prsm_xml",
          "name": "PrSM XML",
          "dataType": "xml",
          "description": "All identified PrSMs in XML format without clustering/filtering"
        },
        {
          "id": "html_folder",
          "name": "HTML Visualization",
          "dataType": "html",
          "description": "HTML files for PrSM and proteoform visualization (open topmsv/index.html in Chrome)"
        }
      ]
    },
